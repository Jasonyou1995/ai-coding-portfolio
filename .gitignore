# =============================================================================
# AI Coding Portfolio - Privacy Protection .gitignore
# 🔴 绝对保护 - 凭证与密钥
# =============================================================================

# Discard any prompts
**/*.prompt

# Environment variables and secrets
.env
.env.local
.env.*.local
!.env.example
*.key
*.pem
*.p12
*.pfx
*.crt
*.cer
config/secrets.yaml
config/secrets.json
**/credentials/
**/secrets/

# API Keys and tokens
api_key.txt
*_api_key*
*_secret*
*_token*
.openai_key
.anthropic_key

# =============================================================================
# 🔴 绝对保护 - 个人敏感信息
# =============================================================================

# Personal data directories
**/personal_data/
**/private_data/
**/real_data/
**/production_data/

# Documents with personal info
*.idcard.*
*.passport.*
resume_real.*
cv_real.*
**/kyc/

_project_docs/
_project_docs/*

# =============================================================================
# 🔴 绝对保护 - 日志与调试信息（可能含敏感信息）
# =============================================================================

logs/
**/logs/*.log
**/logs/debug/
*.log
log/
nohup.out
debug.log
error.log
access.log

# =============================================================================
# Python
# =============================================================================

__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
.hypothesis/
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/

# Virtual environments
venv/
ENV/
env/
.venv/

# =============================================================================
# Node.js
# =============================================================================

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm
.yarn-integrity

# =============================================================================
# IDE & OS
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains
.idea/
*.iml
*.iws

# =============================================================================
# 🟡 脱敏提醒 - 提交前检查
# =============================================================================
# 以下内容提交前必须检查脱敏：
# - 真实邮箱/手机号 → 使用 example.com / **** 占位符
# - 真实姓名 → 使用 GitHub 用户名或昵称
# - 服务器IP/域名 → 使用 <your-domain> 占位符
# - 公司内部数据 → 使用 Mock/Faker 数据
# =============================================================================
